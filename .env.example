# APP_NAME=Ponte Nexus

# ── Banco de dados ────────────────────────────────────────────────────────────
# Opção 1: SQLite local (padrão)
# DATABASE_URL=sqlite:///data/ponte_nexus.db

# Opção 2: SQLite no Google Drive (single-user; não abrir em dois dispositivos ao mesmo tempo)
# DATABASE_URL=sqlite:///G:/My Drive/ponte_nexus/ponte_nexus.db

# Opção 3: PostgreSQL remoto (Railway, Supabase, Neon etc.)
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/ponte_nexus

DATABASE_URL=sqlite:///data/ponte_nexus.db

# ── Ambiente ──────────────────────────────────────────────────────────────────
# development → cria tabelas automaticamente via create_all
# production  → exige `alembic upgrade head` antes de iniciar
ENVIRONMENT=development

# LOG_LEVEL=INFO
# DEBUG=false
